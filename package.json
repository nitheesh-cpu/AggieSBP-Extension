{
  "name": "aggie-professor-compare",
  "version": "2.0.0",
  "description": "Chrome extension to compare professors on Texas A&M registration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:zip": "npm run build && tar -a -cf build.zip -C build .",
    "firefox": "npm run build && node scripts/build-firefox.mjs",
    "firefox:zip": "npm run firefox && tar -a -cf build-firefox.zip -C build-firefox .",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.4",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "typescript": "^5.6.0",
    "vite": "^6.3.5",
    "vite-plugin-static-copy": "^3.1.2"
  }
}